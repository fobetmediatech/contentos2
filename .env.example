# Copy these variable names into Vercel → Project Settings → Environment Variables.
# Set values there — do NOT put actual keys in this file.
#
# Phase 1 (security): Gemini and Apify keys are server-side only (no VITE_ prefix).
# They live in process.env inside the api/ Vercel functions and are never sent to
# the browser. The browser bundle only contains the three VITE_ vars below.

# ----- Auth (Clerk) -----
# Publishable key from clerk.com → Your App → API Keys. Safe to expose publicly (starts with pk_).
# Add team members in Clerk Dashboard → Users → Invite.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# ----- Clerk backend (server-side) -----
# Required by all api/ functions to verify Clerk session JWTs server-side.
# Get from clerk.com → Your App → API Keys → Secret keys. NEVER expose publicly.
CLERK_SECRET_KEY=sk_test_...

# ----- Gemini (server-side) -----
# Used by api/gemini.ts (and api/analyze-reel-video.ts) for all Gemini REST calls.
# Get from aistudio.google.com → API key. NEVER add a VITE_ prefix — this must stay server-side.
GEMINI_API_KEY=AIza...

# ----- Gemini model selection (client, optional) -----
# Model names are not secrets, so these are VITE_ (the browser picks the model; the proxy allowlists
# any gemini-* id). Both are OPTIONAL — unset = gemini-2.5-flash everywhere.
#   VITE_GEMINI_MODEL          → the default model for ALL calls (intent, clarification, content, etc.)
#   VITE_GEMINI_PREMIUM_MODEL  → model for the high-leverage calls ONLY (competitor ranking +
#                                knowledge seed). Defaults to VITE_GEMINI_MODEL. Set to a stronger
#                                model (e.g. gemini-3.5-flash) to upgrade just those without paying
#                                its price on every cheap routing call.
# VITE_GEMINI_MODEL=gemini-2.5-flash
# VITE_GEMINI_PREMIUM_MODEL=gemini-3.5-flash

# ----- Apify (server-side) -----
# Used by api/apify.ts for Instagram scraping. Keys are round-robined per call.
# Get from console.apify.com → Settings → API & Integrations.
# NEVER add a VITE_ prefix — these must stay server-side.
APIFY_KEY_1=apify_api_...
APIFY_KEY_2=apify_api_...    # optional — more keys = more rotation headroom
APIFY_KEY_3=apify_api_...    # optional
APIFY_KEY_4=apify_api_...    # optional
APIFY_KEY_5=apify_api_...    # optional
APIFY_KEY_6=apify_api_...    # optional
APIFY_KEY_7=apify_api_...    # optional
APIFY_KEY_8=apify_api_...    # optional
APIFY_KEY_9=apify_api_...    # optional
APIFY_KEY_10=apify_api_...   # optional

# ----- Data sync (Supabase) -----
# Public/safe to expose in the client bundle (RLS protects the data).
# From Supabase dashboard → Project Settings → API.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...   # anon / publishable key

# ----- Google export (Docs / Sheets) -----
# Public OAuth client id (safe to expose). Powers "Export to Google Docs/Sheets" on results.
# Setup: Google Cloud Console → enable the Google Docs, Sheets, and Drive APIs → create an
# OAuth 2.0 Client ID (type: Web application) → add your app origins (e.g. http://localhost:3000
# and your prod URL) under "Authorized JavaScript origins". No client secret is needed — the
# browser requests the drive.file scope directly via a popup. Leave unset to hide/disable export.
VITE_GOOGLE_CLIENT_ID=<client-id>.apps.googleusercontent.com
