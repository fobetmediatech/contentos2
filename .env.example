# Copy these variable names into Vercel → Project Settings → Environment Variables.
# Set values there — do NOT put actual keys in this file.
#
# VITE_ prefix = baked into the client bundle at build time.
# Acceptable for internal team deployments; not for public production.

VITE_GEMINI_KEY=AIza...
VITE_APIFY_KEY_1=apify_api_...
VITE_APIFY_KEY_2=apify_api_...    # optional — add up to 10 for rotation
VITE_APIFY_KEY_3=apify_api_...    # optional
VITE_APIFY_KEY_4=apify_api_...    # optional
VITE_APIFY_KEY_5=apify_api_...    # optional
VITE_APIFY_KEY_6=apify_api_...    # optional
VITE_APIFY_KEY_7=apify_api_...    # optional
VITE_APIFY_KEY_8=apify_api_...    # optional
VITE_APIFY_KEY_9=apify_api_...    # optional
VITE_APIFY_KEY_10=apify_api_...   # optional
