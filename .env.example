# Copy these variable names into Vercel → Project Settings → Environment Variables.
# Set values there — do NOT put actual keys in this file.
#
# VITE_ prefix = baked into the client bundle at build time.
# Acceptable for internal team deployments; not for public production.
# Keys are configured HERE only — the app has no in-app key entry (no Settings page),
# so changing a VITE_ key means a rebuild/redeploy.

# ----- Auth (Clerk) -----
# Publishable key from clerk.com → Your App → API Keys. Safe to expose publicly (starts with pk_).
# Add team members in Clerk Dashboard → Users → Invite.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

VITE_GEMINI_KEY=AIza...
# OR a POOL of Gemini keys (comma-separated) — rotated per call to spread concurrent multi-user
# load so no single key's per-minute rate limit (RPM/TPM) is the bottleneck. Each Google AI Studio
# account/project has its own free quota; add several for a team. VITE_GEMINI_KEY joins the pool too.
# VITE_GEMINI_KEYS=AIza...aaa,AIza...bbb,AIza...ccc
VITE_APIFY_KEY_1=apify_api_...
VITE_APIFY_KEY_2=apify_api_...    # optional — more keys = more rotation headroom (no cap)
VITE_APIFY_KEY_3=apify_api_...    # optional
VITE_APIFY_KEY_4=apify_api_...    # optional
VITE_APIFY_KEY_5=apify_api_...    # optional
VITE_APIFY_KEY_6=apify_api_...    # optional
VITE_APIFY_KEY_7=apify_api_...    # optional
VITE_APIFY_KEY_8=apify_api_...    # optional
VITE_APIFY_KEY_9=apify_api_...    # optional
VITE_APIFY_KEY_10=apify_api_...   # optional
# OR supply any number of Apify keys as one comma-separated value (no 10-key cap):
# VITE_APIFY_KEYS=apify_api_aaa,apify_api_bbb,apify_api_ccc

# ----- Reel intelligence (deep multimodal) — serverless function -----
# Server-side ONLY (NOT VITE_ prefixed — never sent to the browser). Set in Vercel.
# The /api/analyze-reel-video function uses this Gemini key for the Files-API video calls.
# The function is gated by Clerk JWT verification (CLERK_SECRET_KEY below) — no shared secret needed.
GEMINI_API_KEY=AIza...

# ----- Clerk backend (server-side) -----
# Required by api/analyze-reel-video.ts to verify Clerk session JWTs server-side.
# Get from clerk.com → Your App → API Keys → Secret keys. NEVER expose publicly.
CLERK_SECRET_KEY=sk_test_...

# ----- Data sync (Supabase) -----
# Public/safe to expose in the client bundle (RLS protects the data).
# From Supabase dashboard → Project Settings → API.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...   # anon / publishable key
